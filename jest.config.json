{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/src", "<rootDir>/tests"],
  "testMatch": ["**/*.test.ts"],
  "transform": {
    "^.+\\.tsx?$": ["ts-jest", {
      "tsconfig": {
        "compilerOptions": {
          "module": "commonjs"
        }
      }
    }]
  },
  "moduleNameMapper": {
    "^@db/(.*)$": "<rootDir>/src/db/$1",
    "^@models/(.*)$": "<rootDir>/src/models/$1",
    "^@types/(.*)$": "<rootDir>/src/types/$1",
    "^@api/(.*)$": "<rootDir>/src/api/$1"
  },
  "testTimeout": 30000,
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/index.ts"
  ]
}
