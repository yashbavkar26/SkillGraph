{
  "name": "skillgraph",
  "version": "1.0.0",
  "description": "A dynamic, verifiable graph of micro-skills connecting talent to opportunity",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:api": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:ui": "vite",
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsc -p tsconfig.server.json",
    "build:ui": "vite build",
    "start": "node dist/index.js",
    "preview:ui": "vite preview",
    "test": "jest --runInBand",
    "test:integration": "jest tests/integration --runInBand",
    "db:init": "ts-node src/db/schema.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "lucide-react": "^1.8.0",
    "neo4j-driver": "^5.18.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.14.2",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jest": "^29.7.0",
    "jiti": "^2.6.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9"
  }
}
